{
  "name": "crm-course-foundation",
  "version": "1.0.0",
  "description": "CRM course foundation with React + Express + Prisma (MVC)",
  "main": "index.js",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "start:backend": "npm --prefix backend run start",
    "serve:backend": "node ./backend/src/server.js",
    "certs": "npm --prefix backend run certs",
    "certs:mkcert": "npm --prefix backend run certs:mkcert",
    "mkcert:download": "npm --prefix backend run mkcert:download",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:generate:clean": "npm --prefix backend run prisma:generate:clean",
    "test": "npm --prefix frontend test -- --run",
    "test:recording": "npm --prefix frontend test -- --run src/lib/domRegionRecorder.test.js",
    "test:video:unit": "pytest tests/test_video_recording_unit.py -q",
    "test:video:frontend": "npm --prefix frontend test -- --run src/lib/domRegionRecorder.test.js",
    "test:video:api": "pytest tests/test_video_sessions_api.py tests/test_client_invite.py tests/test_video_upload_recording.py -q",
    "test:functional": "pytest tests/test_functional_table_4_1.py -v",
    "test:docker:seed": "pytest tests/test_docker_seed_api.py -s -k verify",
    "test:docker:seed:api": "pytest tests/test_docker_seed_api.py -s -k seed_docker_demo",
    "test:workbooks": "python tests/generate_test_workbooks.py"
  },
  "dependencies": {},
  "devDependencies": {}
}
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_course"
# Для npm run db:test-data (если в DATABASE_URL указан app_admin):
DATABASE_URL_ADMIN="postgresql://postgres:postgres@localhost:5432/crm_course"
# POSTGRES_PASSWORD=postgres
# POSTGRES_SEED_URL="postgresql://postgres:postgres@localhost:5432/crm_course"
# Публичный URL SPA для Meet-ссылок (совпадает с origin в браузере)
PUBLIC_APP_URL=https://localhost:5173
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# HTTPS/TLS — «замочек» на localhost: mkcert + npm run certs:mkcert (из корня или backend), затем mkcert -install один раз на ПК.
# Самоподписанный npm run certs без mkcert → браузер покажет ERR_CERT_AUTHORITY_INVALID.
HTTPS_ENABLED=true
HTTPS_PORT=4443
# Пути относительно каталога backend (файлы создаёт certs:mkcert).
HTTPS_KEY_PATH="../certs/mkcert-localhost-key.pem"
HTTPS_CERT_PATH="../certs/mkcert-localhost.pem"
HTTPS_CA_PATH=""
HTTP_REDIRECT_TO_HTTPS=false
ENFORCE_HTTPS=false
TRUST_PROXY=false

# Telegram (BotFather). Для Docker — те же переменные в корневом .env (см. deploy/docker-compose.yml).
# На localhost без публичного URL используйте polling, не webhook.
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_ENABLED=true
# TELEGRAM_BOT_API_BASE=https://api.telegram.org
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_POLLING_INTERVAL_MS=1500
# TELEGRAM_POLLING_TIMEOUT_SEC=25

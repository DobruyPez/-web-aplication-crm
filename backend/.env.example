PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_course"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# HTTPS/TLS — «замочек» на localhost: mkcert + npm run certs:mkcert (из корня или backend), затем mkcert -install один раз на ПК.
# Самоподписанный npm run certs без mkcert → браузер покажет ERR_CERT_AUTHORITY_INVALID.
HTTPS_ENABLED=true
HTTPS_PORT=4443
# Пути относительно каталога backend (файлы создаёт certs:mkcert).
HTTPS_KEY_PATH="../certs/mkcert-localhost-key.pem"
HTTPS_CERT_PATH="../certs/mkcert-localhost.pem"
HTTPS_CA_PATH=""
HTTP_REDIRECT_TO_HTTPS=false
ENFORCE_HTTPS=false
TRUST_PROXY=false

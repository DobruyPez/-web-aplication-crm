generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  fullName   String     @map("full_name") @db.VarChar(255)
  email      String     @unique @db.VarChar(255)
  password   String     @map("password_hash") @db.VarChar(255)
  telegramLink   String?    @map("telegram_link") @db.VarChar(255)
  telegramChatId String?    @map("telegram_chat_id") @db.VarChar(64)
  role       String     @default("manager") @db.VarChar(20)
  phone      String?    @db.VarChar(30)
  clients    Client[]
  deals      Deal[]
  tasks      Task[]     @relation("TaskAuthor")
  calls      Call[]     @relation("CallCaller")
  documents  Document[] @relation("DocumentUploader")
  videoSessions VideoSession[] @relation("VideoSessionManager")
  clientInviteTokens ClientInviteToken[] @relation("ClientInviteManager")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @map("updated_at")

  @@map("users")
}

model Client {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(255)
  phone       String?
  email      String?
  address    String?
  notes      String?
  managerId  Int        @map("manager_id")
  manager    User       @relation(fields: [managerId], references: [id], onDelete: Restrict)
  deals      Deal[]
  tasks      Task[]
  calls      Call[]
  documents  Document[]
  inviteTokens ClientInviteToken[]
  videoSessions VideoSession[]
  contactPersons ClientContactPerson[]
  contactPoints  ClientContactPoint[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @map("updated_at")

  @@map("clients")
}

/** Контактное лицо клиента (несколько человек с каналами связи). */
model ClientContactPerson {
  id        Int      @id @default(autoincrement())
  clientId  Int      @map("client_id")
  fullName  String   @map("full_name") @db.VarChar(255)
  role      String?  @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channels  ClientContactPoint[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([clientId])
  @@map("client_contact_persons")
}

model ClientContactPoint {
  id              Int      @id @default(autoincrement())
  clientId        Int      @map("client_id")
  contactPersonId Int?     @map("contact_person_id")
  type            String   @db.VarChar(20)
  value           String   @db.VarChar(255)
  contactName     String   @map("contact_name") @db.VarChar(255)
  sortOrder       Int      @default(0) @map("sort_order")
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactPerson   ClientContactPerson? @relation(fields: [contactPersonId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@index([clientId])
  @@index([contactPersonId])
  @@map("client_contact_points")
}

model Deal {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  productName String    @map("product_name") @db.VarChar(255)
  description String?
  amount      Decimal?  @db.Decimal(12, 2)
  stage       String    @default("new")
  closingDate DateTime? @map("closing_date") @db.Date
  clientId    Int       @map("client_id")
  managerId   Int       @map("manager_id")
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  manager     User      @relation(fields: [managerId], references: [id], onDelete: Restrict)
  tasks          Task[]
  dealDocuments  DealDocument[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @map("updated_at")

  @@map("deals")
}

model DealDocument {
  dealId     Int      @map("deal_id")
  documentId Int      @map("document_id")
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([dealId, documentId])
  @@map("deal_documents")
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      String    @default("new")
  priority    String    @default("medium")
  dueDate     DateTime? @map("due_date")
  authorId    Int       @map("author_id")
  clientId    Int?      @map("client_id")
  dealId      Int?      @map("deal_id")
  author      User      @relation("TaskAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  @@map("tasks")
}

model Call {
  id               Int       @id @default(autoincrement())
  clientId         Int       @map("client_id")
  callerId         Int       @map("caller_id")
  direction        String    @default("out")
  status           String    @default("completed")
  duration         Int?
  recordingUrl     String?   @map("recording_url")
  startedAt        DateTime  @map("started_at")
  endedAt          DateTime? @map("ended_at")
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caller           User      @relation("CallCaller", fields: [callerId], references: [id], onDelete: Restrict)

  @@map("calls")
}

model Document {
  id          Int       @id @default(autoincrement())
  clientId    Int       @map("client_id")
  uploaderId  Int       @map("uploader_id")
  filename    String
  filePath    String    @map("file_path")
  fileSize    Int?      @map("file_size")
  mimeType    String?   @map("mime_type")
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploader      User           @relation("DocumentUploader", fields: [uploaderId], references: [id], onDelete: Restrict)
  dealDocuments DealDocument[]

  @@map("documents")
}

model ClientInviteToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(64)
  clientId  Int      @map("client_id")
  managerId Int      @map("manager_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  manager   User     @relation("ClientInviteManager", fields: [managerId], references: [id], onDelete: Restrict)

  @@map("client_invite_tokens")
}

model VideoSession {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  managerId           Int       @map("manager_id")
  clientId            Int       @map("client_id")
  direction           String    @default("out") @db.VarChar(10)
  guestToken          String    @unique @map("guest_token") @db.VarChar(64)
  status              String    @default("active") @db.VarChar(20)
  recordingStartedAt  DateTime? @map("recording_started_at")
  recordingUrl        String?   @map("recording_url")
  startedAt           DateTime  @default(now()) @map("started_at")
  endedAt             DateTime? @map("ended_at")
  manager             User      @relation("VideoSessionManager", fields: [managerId], references: [id], onDelete: Restrict)
  client              Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("video_sessions")
}

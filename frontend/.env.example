VITE_API_BASE_URL=https://localhost:4443/api
# Если HTTPS выключён на API: http://localhost:4000/api (или ваш PORT)
# TLS backend (отдельный порт API):
# VITE_API_BASE_URL=https://localhost:4443/api
# SPA отдаётся с того же хоста, что и API (npm run serve:backend / HTTPS на 4443):
# VITE_API_BASE_URL=/api

# Origin SPA в браузере (Meet-ссылки /calls/join/…). Должен совпадать с PUBLIC_APP_URL на backend.
VITE_PUBLIC_APP_URL=https://localhost:5173

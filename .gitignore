# --- Зависимости Node.js ---
node_modules/
**/node_modules/

# --- Сборка и кэш ---
dist/
dist-ssr/
frontend/dist/
build/
.vite/
*.tsbuildinfo
.cache/

# --- Переменные окружения и секреты ---
.env
.env.*
!.env.example
!**/.env.example
backend/.env
frontend/.env
.env.local
*.local

# --- Python (тесты) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage/
*.egg-info/
.eggs/
.venv/
venv/
env/

# --- Prisma / БД (локальные артефакты) ---
# Схему и seed коммитим; игнорируем только локальный кэш движка при сбоях generate
backend/node_modules/.prisma/
*.db
*.sqlite
*.sqlite-journal

# --- Загрузки пользователей (файлы на диске) ---
backend/uploads/docs/*
!backend/uploads/docs/.gitkeep
backend/uploads/voice/*
!backend/uploads/voice/.gitkeep
backend/uploads/**/.files-index.json

# --- TLS-ключи и сертификаты (mkcert / самоподписанные) ---
/certs/*.pem
/certs/*.key
/certs/*.crt

# Локально скачанный mkcert (npm run mkcert:download)
/tools/mkcert.exe
/tools/mkcert

# --- Логи и отладка ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- IDE и ОС ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# --- Cursor (локальные логи и кэш IDE) ---
.cursor/debug-*.log
.cursor/*.log

# --- Docker / deploy (локальные образы и тома) ---
*.tar
docker-compose.override.yml
.deploy/

# --- Прочее ---
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
